# Boş = Vite proxy (CORS yok). Lokal backend: VITE_API_PROXY_TARGET=http://localhost:5207
# Canlı Railway:
# VITE_API_PROXY_TARGET=https://fashion-production-bc9c.up.railway.app
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=

# Firebase Authentication (Google ile giriş — önerilen)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend: Firebase Console → Authentication → Google → Web client ID
# Auth:Google:ClientId veya Auth__Google__ClientId
# GIS (Firebase yoksa): Google Cloud → Credentials → Web client → Authorized JavaScript origins
#   http://localhost:5173  https://design.nulatechnology.com
# VITE_GOOGLE_CLIENT_ID=
